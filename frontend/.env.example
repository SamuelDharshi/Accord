# ─── Accord Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is already in .gitignore.

# ── Sui Network ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── Accord Package (deployed Move contract) ──────────────────────────────────
# Run: sui client publish --gas-budget 200000000 contracts/accord
# Then copy the packageId from the output.
NEXT_PUBLIC_ACCORD_PACKAGE_ID=0x832f93729a8b1dfe9dd8067536dfa35231cf019f9401afe04a398df6d18c54cb

# ── Arca Agent API ───────────────────────────────────────────────────────────
# Local: start with `cd agent && npm run start`
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001

# ── Walrus Testnet ───────────────────────────────────────────────────────────
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# ── Google OAuth / zkLogin ───────────────────────────────────────────────────
# REQUIRED for zkLogin. Steps:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID (type: Web application)
#   3. Add Authorized redirect URIs:
#        http://localhost:3000/auth/callback    (local dev)
#        https://your-domain.vercel.app/auth/callback  (production)
#   4. Copy the Client ID (looks like: 123456789-abc.apps.googleusercontent.com)
#   5. Paste it below. Without this, the zkLogin button will show a warning.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
