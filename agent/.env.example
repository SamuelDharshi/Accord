# Arca Agent Environment Variables
# Copy to .env and fill in values before running.

# ── Sui Network ──────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ── Arca Wallet ───────────────────────────────────────────────────────────────
# The private key of the Arca agent wallet (holds ArcaCap).
# In production: use an HSM or secret manager. Never commit this value.
ARCA_PRIVATE_KEY=

# ── Accord On-Chain IDs ───────────────────────────────────────────────────────
ACCORD_PACKAGE_ID=
ARCA_CAP_OBJECT_ID=
ACCORD_TREASURY_ADDRESS=

# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Walrus ────────────────────────────────────────────────────────────────────
WALRUS_NETWORK=testnet
# Walrus aggregator endpoint (for reads)
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Walrus publisher endpoint (for writes)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Epochs for deliverable storage (~2 years)
WALRUS_DELIVERABLE_EPOCHS=104
# Epochs for proof certificate storage (~10 years)
WALRUS_CERT_EPOCHS=520

# ── Agent Service ─────────────────────────────────────────────────────────────
PORT=3001
# Minimum confidence for auto-release (0-100)
AUTO_RELEASE_CONFIDENCE_THRESHOLD=80
# Max PTBs per minute (rate limiting)
PTB_RATE_LIMIT=100
